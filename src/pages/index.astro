---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = 'JAV50 — Just AI Video Top 50';
const pageDescription = 'The ultimate ranking of the top 50 AI video generators, from Sora to Runway and Pika.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://jav50.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="The Top 50 AI Video Generators Ranked" subtitle="Discover the state-of-the-art in text-to-video and image-to-video AI generation." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="Text-to-Video" description="Generate video from prompts" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="Avatars" description="AI Talking Heads" href="/en/categories/c2/" tag="New" />
      <Card title="Video Editing" description="AI-assisted editing tools" href="/en/categories/c3/" />
      <Card title="Animation" description="2D/3D AI Animation" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="Sora vs Runway Gen-3" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="Top 10 AI Avatar Makers" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="Best Free AI Video Tools" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>
