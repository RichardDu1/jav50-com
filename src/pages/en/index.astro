---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allGenerators = await getCollection('generators');
// Sort by rank ascending
const topGenerators = allGenerators.sort((a, b) => a.data.rank - b.data.rank).slice(0, 3);

const pageTitle = 'JAV50: Top 50 AI Video Generators Ranked';
const pageDescription = 'The ultimate leaderboard for AI video generation. We test and rank the top 50 models including Sora, Runway, Kling, and Luma.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://jav50.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <!-- Cinematic Hero -->
  <header class="bg-surface text-text py-32 relative overflow-hidden flex flex-col items-center text-center">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/30 via-surface to-surface -z-10"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-30 -z-20"></div>
    
    <div class="px-4 py-1.5 rounded-full border border-primary/30 bg-primary/10 text-primary-dark text-sm font-bold mb-8 backdrop-blur-md">
      🎬 2026 TOP 50 LEADERBOARD IS LIVE
    </div>

    <h1 class="text-6xl md:text-8xl font-black mb-6 max-w-5xl leading-none tracking-tighter">
      The Ultimate AI <br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Video Generator</span> Ranking.
    </h1>
    
    <p class="text-xl md:text-2xl text-muted max-w-3xl mb-12 font-medium">
      Stop wasting credits on bad models. We benchmark and rank the top 50 AI video generators for realism, motion, and prompt adherence.
    </p>
    
    <div class="flex gap-4">
      <a href="/en/generators/" class="bg-gradient-to-r from-primary to-accent text-white font-bold px-10 py-5 rounded-full hover:scale-105 transition-transform shadow-[0_0_30px_rgba(168,85,247,0.4)]">
        View the Top 50 List
      </a>
    </div>
  </header>

  <!-- Top 3 Showcase -->
  <section class="container max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-4">The Holy Trinity of AI Video</h2>
      <p class="text-muted text-lg">The undisputed top 3 models dominating the current benchmark.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {topGenerators.length > 0 ? topGenerators.map((gen, idx) => (
        <a href={`/en/generators/${gen.id.split('/').pop()}`} class="bg-neutral rounded-2xl border border-border p-8 hover:border-primary transition-colors group relative overflow-hidden shadow-2xl">
          <div class="absolute -right-10 -top-10 text-[150px] font-black text-white/5 group-hover:text-primary/10 transition-colors z-0">
            {idx + 1}
          </div>
          <div class="relative z-10">
            <span class="inline-block bg-primary text-white text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full mb-4">
              Rank #{gen.data.rank}
            </span>
            <h3 class="text-3xl font-black text-white mb-2">{gen.data.title}</h3>
            <span class="block text-sm text-muted uppercase tracking-widest mb-6 border-b border-border pb-4">{gen.data.videoType} • {gen.data.maxResolution}</span>
            <p class="text-muted leading-relaxed mb-6">
              {gen.data.description.substring(0, 100)}...
            </p>
            <div class="text-accent font-bold group-hover:translate-x-2 transition-transform">
              Read Full Review →
            </div>
          </div>
        </a>
      )) : (
        <div class="col-span-3 text-center py-20 border-2 border-dashed border-border rounded-2xl text-muted font-bold">
          Running cinematic benchmarks...
        </div>
      )}
    </div>
    
    <div class="mt-16 text-center">
      <a href="/en/generators/" class="inline-flex items-center gap-2 text-white font-bold px-8 py-4 rounded-full border border-border hover:border-primary transition-colors hover:bg-neutral">
        See Ranks 4-50 
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>
</BaseLayout>
