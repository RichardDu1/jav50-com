---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const generators = await getCollection('generators');
  return generators.map(gen => ({
    params: { slug: gen.id.split('/').pop() },
    props: { gen },
  }));
}

const { gen } = Astro.props;
const { Content } = await render(gen);

// Schema Markup
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": gen.data.title,
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "description": gen.data.description
};
---

<BaseLayout
  title={`${gen.data.title} AI Video Review | Rank #${gen.data.rank} | JAV50`}
  description={gen.data.description}
  canonical={`https://jav50.com/en/generators/${gen.id.split('/').pop()}/`}
  schema={{ type: 'SoftwareApplication', data: softwareSchema }}
>
  <div class="bg-surface text-text min-h-screen py-24">
    <div class="container max-w-5xl mx-auto px-6">
      
      <!-- Breadcrumbs -->
      <nav class="mb-12 text-sm text-muted font-bold tracking-widest uppercase">
        <a href="/en/generators/" class="hover:text-primary transition-colors">Leaderboard</a>
        <span class="mx-3">/</span>
        <span class="text-white">{gen.data.title}</span>
      </nav>

      <!-- Cinematic Header -->
      <header class="mb-16 relative">
        <div class="absolute -left-12 -top-12 w-48 h-48 bg-primary/20 rounded-full blur-[100px] pointer-events-none"></div>
        <div class="absolute right-0 bottom-0 w-64 h-64 bg-accent/10 rounded-full blur-[120px] pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-start gap-8">
          <div>
            <div class="inline-block bg-primary text-white font-black px-4 py-1 rounded-full text-sm uppercase tracking-widest mb-6">
              Rank #{gen.data.rank} on JAV50
            </div>
            <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter mb-6">{gen.data.title}</h1>
            <p class="text-2xl text-muted max-w-2xl font-medium leading-relaxed">{gen.data.description}</p>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Specs Sidebar -->
        <aside class="lg:col-span-4 order-2 lg:order-1">
          <div class="bg-neutral border border-border p-8 rounded-3xl sticky top-8 shadow-2xl">
            <h3 class="text-white font-black text-xl mb-6 tracking-tight">Technical Specs</h3>
            
            <ul class="space-y-6">
              <li class="border-b border-border pb-4">
                <span class="block text-xs uppercase tracking-widest text-muted mb-1">Generation Type</span>
                <span class="font-bold text-lg text-white">{gen.data.videoType}</span>
              </li>
              <li class="border-b border-border pb-4">
                <span class="block text-xs uppercase tracking-widest text-muted mb-1">Max Resolution</span>
                <span class="font-bold text-lg text-primary">{gen.data.maxResolution}</span>
              </li>
              <li class="border-b border-border pb-4">
                <span class="block text-xs uppercase tracking-widest text-muted mb-1">Pricing Model</span>
                <span class="font-bold text-lg text-accent">{gen.data.pricing}</span>
              </li>
            </ul>

            <div class="mt-8">
              <h4 class="text-xs uppercase tracking-widest text-muted mb-4 font-bold">Key Strengths</h4>
              <ul class="space-y-3">
                {gen.data.keyFeatures.map(feature => (
                  <li class="flex items-start gap-3 text-sm text-white font-medium">
                    <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <button class="w-full mt-10 bg-white text-surface font-black py-4 rounded-xl hover:bg-primary hover:text-white transition-colors uppercase tracking-widest text-sm">
              Try {gen.data.title}
            </button>
          </div>
        </aside>

        <!-- Main Review -->
        <article class="lg:col-span-8 order-1 lg:order-2">
          <!-- Mock Video Player -->
          <div class="w-full aspect-video bg-black rounded-3xl border border-border flex items-center justify-center mb-12 shadow-2xl overflow-hidden relative group">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/10 to-accent/5"></div>
            <svg class="w-20 h-20 text-white/50 group-hover:text-white transition-colors group-hover:scale-110 duration-300" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
            <div class="absolute bottom-4 left-6 text-sm text-white/50 font-mono tracking-widest">PROMPT: CINEMATIC PANNING SHOT, 4K, HYPERREALISTIC...</div>
          </div>

          <div class="prose prose-invert prose-lg max-w-none 
            prose-headings:font-black prose-headings:tracking-tight prose-headings:text-white
            prose-h2:text-4xl prose-h2:mt-16 prose-h2:mb-8
            prose-h3:text-2xl prose-h3:text-primary
            prose-p:text-muted prose-p:leading-relaxed
            prose-a:text-accent hover:prose-a:text-white
            prose-strong:text-white">
            <Content />
          </div>
        </article>
      </div>

    </div>
  </div>
</BaseLayout>
